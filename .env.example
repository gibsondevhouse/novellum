# Novellum environment variables
# Copy this file to .env.local and fill in any overrides.
# AI provider keys are NOT stored here as of plan-017 stage-005 — they are
# managed through the in-app Settings UI and persisted via the server-side
# credential service (see src/lib/server/credentials/).

# Path to SQLite database file (default: ./novellum.db)
NOVELLUM_DB_PATH=./novellum.db
