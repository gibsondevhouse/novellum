{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Novellum",
  "version": "0.0.1",
  "identifier": "com.gibsondevhouse.novellum",
  "build": {
    "frontendDist": "../build/client",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && node scripts/prepare-sidecar-deps.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "Novellum",
        "width": 1400,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Gibson Dev House",
    "category": "Productivity",
    "shortDescription": "Novel-writing app with AI assistance.",
    "longDescription": "Novellum is a desktop novel-writing environment with autosave, snapshot history, and built-in AI assistants for outlining, drafting, and continuity checks.",
    "copyright": "Copyright © 2026 Gibson Dev House. All rights reserved.",
    "resources": [
      "../build/**/*"
    ],
    "externalBin": [
      "binaries/node"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
