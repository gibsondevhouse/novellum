		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"dexie": "^4.4.2",
		"diff": "^8.0.4",
		"docx": "^9.6.1",
		"epub-gen-memory": "^1.1.2",
		"isomorphic-dompurify": "^3.8.0",
		"jszip": "^3.10.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6"
