{
	"name": "novellum",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"lint:css": "stylelint \"src/**/*.{css,svelte}\"",
		"lint:css:fix": "stylelint \"src/**/*.{css,svelte}\" --fix",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"check:tokens": "node scripts/check-visual-tokens.mjs",
		"test:visual": "playwright test tests/visual/",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"tauri": "tauri",
		"desktop:dev": "tauri dev",
		"desktop:build": "tauri build",
		"desktop:preview": "tauri build --debug"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@storybook/addon-a11y": "^10.3.5",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/svelte": "10.3.5",
		"@storybook/sveltekit": "^10.3.5",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/cli": "^2.10.1",
		"@types/better-sqlite3": "^7.6.13",
		"@types/diff": "^8.0.0",
		"@types/dompurify": "^3.2.0",
		"@types/node": "^25.6.0",
		"@typescript-eslint/eslint-plugin": "^8.58.1",
		"@typescript-eslint/parser": "^8.58.1",
		"@vitest/coverage-v8": "^4.1.4",
		"autoprefixer": "^10.5.0",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-boundaries": "^6.0.2",
		"eslint-plugin-svelte": "^3.17.0",
		"fake-indexeddb": "^6.2.5",
		"globals": "^17.5.0",
		"jsdom": "^29.0.2",
		"postcss": "^8.5.10",
		"postcss-html": "^1.8.1",
		"prettier": "^3.8.2",
		"prettier-plugin-svelte": "^3.5.1",
		"storybook": "^10.3.5",
		"stylelint": "^17.8.0",
		"stylelint-config-html": "^1.1.0",
		"stylelint-config-standard": "^40.0.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "3.4.17",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"@lucide/svelte": "^1.8.0",
		"@tiptap/core": "^3.22.4",
		"@tiptap/extension-document": "^3.22.4",
		"@tiptap/extension-history": "^3.22.4",
		"@tiptap/extension-paragraph": "^3.22.4",
